{
	"name": "retrieve-changed-files",
	"description": "GitHub action that retrieves all changed files in a pull request or push.",
	"version": "3.0.0",
	"private": true,
	"author": "MASES s.r.l. (original author Jitterbit, Inc.)",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/masesgroup/retrieve-changed-files.git"
	},
	"homepage": "https://github.com/masesgroup/retrieve-changed-files#readme",
	"bugs": {
		"url": "https://github.com/masesgroup/retrieve-changed-files/issues"
	},
	"keywords": [
		"GitHub",
		"Actions",
		"TypeScript",
		"JavaScript",
		"Get",
		"Changed",
		"Modified",
		"Diff",
		"Files"
	],
	"main": "lib/main.js",
	"engines": {
		"node": ">=20.*.*"
	},
	"scripts": {
		"build": "tsc",
		"clean": "rimraf --glob dist/**/* lib/**/*",
		"format": "prettier --write **/*.ts",
		"format-check": "prettier --check \"{,!(node_modules)/**/}*.ts\"",
		"lint": "eslint src/**/*.ts",
		"package": "ncc build",
		"test": "jest",
		"all": "yarn clean && yarn build && yarn format && yarn lint && yarn package && yarn test"
	},
	"dependencies": {
		"@actions/core": "^3.0.1",
		"@actions/github": "^9.1.1"
	},
	"devDependencies": {
		"@octokit/rest": "^22.0.1",
		"@types/jest": "^30.0.0",
		"@types/node": "^26.1.0",
		"@typescript-eslint/eslint-plugin": "^8.62.0",
		"@typescript-eslint/parser": "^8.62.1",
		"@vercel/ncc": "^0.44.0",
		"eslint": "^9.39.4",
		"eslint-plugin-github": "^6.0.0",
		"eslint-plugin-jest": "^29.15.3",
		"eslint-plugin-prettier": "^5.5.6",
		"jest": "^30.4.2",
		"jest-circus": "^30.4.2",
		"js-yaml": "^5.2.0",
		"prettier": "^3.9.4",
		"rimraf": "^6.1.3",
		"ts-jest": "^29.4.11",
		"typescript": "^6.0.3"
	}
}
